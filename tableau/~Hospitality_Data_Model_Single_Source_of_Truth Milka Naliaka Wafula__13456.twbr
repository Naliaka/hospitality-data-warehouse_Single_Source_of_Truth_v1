    <worksheet name='Total Revenue'>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_bookings.csv+ (Multiple Connections)' name='federated.1x6bgsu1iy0eyn11mww7e11l2iig' />
          </datasources>
          <datasource-dependencies datasource='federated.1x6bgsu1iy0eyn11mww7e11l2iig'>
            <column caption='Total Stay Cost' datatype='integer' name='[Calculation_1906060179902464]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Days] * [day_rate]' />
            </column>
            <column caption='Total Service Cost' datatype='integer' name='[Calculation_1906060181504001]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Unit] * [Servise Rate]' />
            </column>
            <column caption='Total Before Discount' datatype='integer' name='[Calculation_1906060181835778]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1906060179902464] + [Calculation_1906060181504001]' />
            </column>
            <column caption='Discount' datatype='real' name='[Calculation_1906060182048771]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_1906060181835778] &gt; 50000 THEN [Calculation_1906060181835778] * 0.2 ELSE 0 END' />
            </column>
            <column caption='Final Total' datatype='real' name='[Calculation_1906060182589444]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1906060181835778] - [Calculation_1906060182048771]' />
            </column>
            <column caption='Total Revenue' datatype='real' name='[Calculation_1906060197482507]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_1906060182589444])' />
            </column>
            <column datatype='integer' name='[Days]' role='measure' type='quantitative' />
            <column caption='Service Rate' datatype='integer' name='[Servise Rate]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Unit]' role='measure' type='quantitative' />
            <column caption='Day Rate' datatype='integer' name='[day_rate]' role='dimension' type='quantitative' />
            <column caption='Hotel Name' datatype='string' name='[hotel_name]' role='dimension' type='nominal' />
            <column caption='Loyalty Tier' datatype='string' name='[loyalty_tier]' role='dimension' type='nominal' />
