      <aliases enabled='yes' />
      <column caption='Discount Flag' datatype='string' name='[Calculation_1594629248040964]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ([total_stay_cost]+[total_service_cost])&gt; 50000 THEN &quot;Discount Applied&quot;&#13;&#10;ELSE &quot;No Discount&quot;&#13;&#10;END' />
      </column>
      <column caption='Avg Stayed Days' datatype='real' name='[Calculation_1594629250883589]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([days_stayed])' />
      </column>
      <column caption='Total Guest' datatype='integer' name='[Calculation_1594629438836748]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([customer_name])' />
      </column>
      <column caption='Avg Stay Rate' datatype='real' name='[Calculation_1594629440126989]' role='measure' type='quantitative'>
