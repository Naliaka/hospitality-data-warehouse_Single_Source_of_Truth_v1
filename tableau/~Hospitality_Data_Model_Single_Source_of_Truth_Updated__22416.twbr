      <aliases enabled='yes' />
      <column caption='Discount Flag' datatype='string' name='[Calculation_1288137143349248]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [total_before_discount] &gt; 50000 THEN &quot;Discount Applied&quot;&#13;&#10;ELSE &quot;No Discount&quot;&#13;&#10;END' />
      </column>
      <column caption='Total Revenue' datatype='integer' name='[Calculation_1906060197482507]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([final_total])' />
      </column>
      <column caption='Total Service Revenue' datatype='integer' name='[Calculation_1906060222058508]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_service_cost])' />
      </column>
      <column caption='Total Guest' datatype='integer' name='[Calculation_1906060229042189]' role='measure' type='quantitative'>
